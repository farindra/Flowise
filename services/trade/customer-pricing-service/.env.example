# customer-pricing-service — sinkronisasi data customer dari Jurnal.id
# Copy ke .env dan isi dengan nilai yang sesuai

PORT=8102
SERVICE_NAME=customer-pricing-service
DATA_DIR=/data

# === JURNAL.ID PARTNER API ===
CUSTOMER_PROFILE_API_URL=https://api.jurnal.id/partner/core/api/v1/contacts/{id}
API_KEY_CUST1=your-jurnal-api-key-1
API_KEY_CUST2=your-jurnal-api-key-2

# === SCHEDULE ===
# Interval sync customer dalam ms (default 1800000 = 30 menit)
CACHE_SYNC_INTERVAL=1800000
