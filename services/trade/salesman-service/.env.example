# salesman-service — Jurnal API wrapper untuk AgentFlow salesman
# Copy ke .env dan isi dengan nilai yang sesuai

PORT=8200

# === JURNAL.ID API ===
JURNAL_API_URL=https://api.jurnal.id/partner/core/api/v1/
JURNAL_BEARER_TOKEN=your-jurnal-bearer-token

# === INTERNAL AUTH ===
# Dipakai Flowise tool calls ke service ini
INTERNAL_KEY=ob-jurnal-internal-2026

# === MEILISEARCH ===
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=your-meilisearch-master-key

# === PRODUCT SEARCH ===
PRODUCT_SEARCH_URL=http://product-search-service:8101

# === SCHEDULE ===
# Interval sync customer dalam jam
CUSTOMER_SYNC_INTERVAL_HOURS=6
