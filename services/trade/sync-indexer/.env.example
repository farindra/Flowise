# sync-indexer — indexer produk ke Meilisearch dari API oceanbearings.co.id
# Copy ke .env dan isi dengan nilai yang sesuai

SERVICE_NAME=sync-indexer

# === MEILISEARCH ===
MEILI_URL=http://meilisearch:7700
MEILI_API_KEY=your-meilisearch-master-key

# === SOURCE API ===
PRODUK_API_URL=https://api.oceanbearings.co.id/get/product/all/1?token=your-api-token
PRODUK_API_URL2=https://api.oceanbearings.co.id/get/product/all/2?token=your-api-token

# === SCHEDULE ===
# Interval sync dalam ms (default 1800000 = 30 menit)
CACHE_SYNC_INTERVAL=1800000
