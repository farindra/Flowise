# product-search-service — pencarian produk via Meilisearch
# Copy ke .env dan isi dengan nilai yang sesuai

PORT=8101
SERVICE_NAME=product-search-service

# === MEILISEARCH ===
# Gunakan service name Docker jika pakai Docker Compose
MEILI_URL=http://meilisearch:7700
MEILI_API_KEY=your-meilisearch-master-key
