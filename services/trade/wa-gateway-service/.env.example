# wa-gateway-service — legacy WA bot (sebelum go-wa)
# DEPRECATED: service ini sudah digantikan oleh go-wa (port 8082)
# Dipertahankan untuk referensi, jangan digunakan di production baru

PORT=8100
SERVICE_NAME=wa-gateway-service

# Token statis untuk endpoint /qr dan /pair-phone
QR_TOKEN=ob-wa-qr-2026

# Lokasi data persisten
DATA_DIR=/data

# === TRADE SERVICES (Docker) ===
PRODUCT_SEARCH_URL=http://product-search-service:8101
CUSTOMER_PRICING_URL=http://customer-pricing-service:8102
AI_VISION_URL=http://ai-vision-service:8103

MARKETING_NOTIFY_OVERRIDE=

# === MONGODB ===
MONGODB_URI=mongodb+srv://db_user:db_pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ocean_bearings
MONGODB_COLLECTION_HISTORY=chat_history
MONGODB_COLLECTION_USERS=users

# === FLOWISE ===
FLOWISE_URL=https://your-flowise-domain.com
FLOWISE_CHATFLOW_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FLOWISE_API_KEY=your-flowise-api-key

# === INFO KANTOR ===
ALAMAT_KANTOR="Jl. Contoh No.1, Jakarta"
TELPON_KANTOR=021-000-00000
WA_CS1=0812-0000-0001
WA_CS2=0812-0000-0002
EMAIL_KANTOR=info@example.com
MARKETING_MAP=

# === OWNER ASSISTANT ===
OWNER_PHONES=6281234567890
OWNER_CHATFLOW_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === TRADE INTEGRATION ===
TRADE_URL=https://trade.example.com
TRADE_BOT_API_KEY=your-trade-bot-api-key
