# go-telegram — Telegram multi-bot manager
# Copy ke .env dan isi dengan nilai yang sesuai

# === DATABASE (PostgreSQL) ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=flowise
DB_PASSWORD=changeme
DB_NAME=flowise

# === FLOWISE ===
FLOWISE_BASE_URL=https://your-flowise-domain.com
FLOWISE_API_KEY=your-flowise-api-key
FLOWISE_TIMEOUT=120

# === BOT DEFAULTS (seed ke DB pada startup pertama jika tabel kosong) ===
# Customer bot
TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooPP
FLOWISE_CHATFLOW_CUSTOMER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Owner bot
OWNER_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooQQ
FLOWISE_CHATFLOW_OWNER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OWNER_TELEGRAM_IDS=123456789,987654321

# Salesman bot
SALESMAN_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooRR
FLOWISE_CHATFLOW_SALESMAN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === INTERNAL ===
INTERNAL_API_KEY=ob-tg-internal-2026
WEBHOOK_BASE_URL=https://your-flowise-domain.com/telegram
PORT=8081

# === MISC ===
HUMAN_TELEGRAM=@your_admin_username
WAIT_MSG_INTERVAL=6
