# go-wa — WhatsApp multi-session manager (whatsmeow)
# Copy ke .env dan isi dengan nilai yang sesuai

# === DATABASE (PostgreSQL) ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=flowise
DB_PASSWORD=changeme
DB_NAME=flowise

# === FLOWISE ===
FLOWISE_BASE_URL=https://your-flowise-domain.com
FLOWISE_API_KEY=your-flowise-api-key
FLOWISE_TIMEOUT=120

# === STORAGE ===
# Direktori penyimpanan device store per sesi (sqlite per UUID)
DATA_DIR=/data/wa-sessions

# === INTERNAL ===
INTERNAL_API_KEY=ob-wa-internal-2026
PORT=8082
