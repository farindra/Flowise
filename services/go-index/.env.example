# go-index — Meilisearch indexer untuk produk PrestaShop
# Copy ke .env dan isi dengan nilai yang sesuai

# === MEILISEARCH ===
MEILI_MASTER_KEY=your-meilisearch-master-key

# === DB prime-ob (prime.oceanbearings.co.id) ===
DB_PRIME_OB_DSN=db_user:db_pass@tcp(127.0.0.1:3306)/prime-ob?parseTime=true&charset=utf8mb4
DB_PRIME_OB_PREFIX=v1_
DB_PRIME_OB_STORE=prime_ob

# === DB prime-sbb (prime-sbb.oceanbearings.co.id) ===
DB_PRIME_SBB_DSN=db_user:db_pass@tcp(127.0.0.1:3306)/prime-sbb?parseTime=true&charset=utf8mb4
DB_PRIME_SBB_PREFIX=v1_
DB_PRIME_SBB_STORE=prime_sbb

# === SCHEDULE ===
# Interval re-index dalam menit
REINDEX_INTERVAL=10
