# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
.DS_Store

# ── Node / pnpm ───────────────────────────────────────────────────────────────
**/node_modules/
**/.pnpm-store/
**/package-lock.json
!**/examples/package-lock.json
**/yarn.lock

# ── Build output ──────────────────────────────────────────────────────────────
**/dist/
**/build/
**/.turbo/
**/coverage/
**/tmp/
**/temp/
packages/components/nodes/cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
**/logs/
**/*.log

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Certificates & keys ───────────────────────────────────────────────────────
*.key
*.key.json
*.keys
*.priv
*.rsa
*.pem
*.crt
*.csr
*.ca
*.der
*.p12
*.kdb
*.rnd
*.ssleay
*.smime
*.vsix
*.ssh
*.ssh-key
.key-mrc

# ── Uploads & compressed ──────────────────────────────────────────────────────
**/uploads/
**/*.tgz
**/*.zip

# ── Nginx proxy cache ─────────────────────────────────────────────────────────
proxy_cache_dir/

# ── Database & runtime data (bind mounts, never commit) ───────────────────────
**/*.db
**/*.sqlite
services/meilisearch/data/
services/go-index/data/
services/trade/data/

# ── Go compiled binaries ──────────────────────────────────────────────────────
services/trade/wa-gateway-service/migrate
services/go-telegram/bin/
services/go-index/indexer/indexer

# ── Claude ───────────────────────────────────────────────────────────────────
.claude/plans/
.claude/settings.local.json
.claude/agent-memory/
services/trade/.claude/

# ── Flowise proprietary paths ─────────────────────────────────────────────────
extensions/
apps/*/
!apps/oss-app/
